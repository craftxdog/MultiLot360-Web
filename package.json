{
  "name": "multilot-360-web",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "build:desktop": "cd apps/desktop && bun run build",
    "lint:web": "cd apps/web && bun run lint",
    "typecheck:web": "cd apps/web && bun run typecheck",
    "test:web": "cd apps/web && bun run test",
    "check:web": "bun run lint:web && bun run typecheck:web && bun run test:web && bun run build:web"
  }
}
